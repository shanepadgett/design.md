{
  "$schema": "../../../personal/crumbs/schemas/crumbs.schema.json",
  "extensions": {
    "caveman": {
      "enabled": true,
      "powers": ["architecture", "typescript"]
    },
    "quietMarkdownlint": {
      "excludeGlobs": ["external/**", "docs/_hidden/**"]
    },
    "quietMiseTask": {
      "task": "check",
      "excludeGlobs": ["external/**"],
      "trackedExtensions": [".ts"]
    }
  }
}
