{
  "name": "design.md",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "designmd": "./dist/cli/main.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format:fix": "oxfmt --write . \"!dist/**\" \"!external/**\"",
    "format:check": "oxfmt --check . \"!dist/**\" \"!external/**\"",
    "lint:fix": "oxlint . --fix --ignore-pattern \"external/**\" --ignore-pattern \"dist/**\" --no-error-on-unmatched-pattern",
    "lint:check": "oxlint . --ignore-pattern \"external/**\" --ignore-pattern \"dist/**\" --deny-warnings --no-error-on-unmatched-pattern",
    "markdownlint:fix": "markdownlint \"**/*.md\" --ignore \"external/**\" --fix",
    "markdownlint:check": "markdownlint \"**/*.md\" --ignore \"external/**\"",
    "test": "npm run build && node --test test/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "markdownlint-cli": "0.48.0",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "typescript": "6.0.3"
  }
}
