{
  "name": "@shanepadgett/design.md",
  "version": "0.4.0",
  "description": "CLI and library for design documents with structured tokens.",
  "keywords": [
    "cli",
    "design",
    "design-systems",
    "markdown",
    "tokens"
  ],
  "homepage": "https://github.com/shanepadgett/design.md#readme",
  "license": "MIT",
  "author": "Shane Padgett",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shanepadgett/design.md.git"
  },
  "bin": {
    "designmd": "./dist/cli/main.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "coverage": "npm --silent run build && node --test --experimental-test-coverage --test-coverage-include=\"dist/**/*.js\" --test-coverage-branches=90 test/*.test.ts",
    "coverage:lcov": "npm --silent run build && node --test --experimental-test-coverage --test-coverage-include=\"dist/**/*.js\" --test-coverage-branches=90 --test-reporter=lcov --test-reporter-destination=lcov.info test/*.test.ts",
    "spec:update": "node scripts/update-spec-content.mjs",
    "format:fix": "node ./node_modules/oxfmt/bin/oxfmt --write . \"!CHANGELOG.md\" \"!node_modules/**\" \"!dist/**\" \"!external/**\" \"!coverage/**\" \"!.pi/**\" > /dev/null",
    "format:check": "node ./node_modules/oxfmt/bin/oxfmt --list-different . \"!CHANGELOG.md\" \"!node_modules/**\" \"!dist/**\" \"!external/**\" \"!coverage/**\" \"!.pi/**\"",
    "lint:fix": "node ./node_modules/oxlint/bin/oxlint . --fix --format unix --ignore-pattern \"node_modules/**\" --ignore-pattern \"dist/**\" --ignore-pattern \"external/**\" --ignore-pattern \"coverage/**\" --ignore-pattern \".pi/**\" --no-error-on-unmatched-pattern",
    "lint:check": "node ./node_modules/oxlint/bin/oxlint . --format unix --ignore-pattern \"node_modules/**\" --ignore-pattern \"dist/**\" --ignore-pattern \"external/**\" --ignore-pattern \"coverage/**\" --ignore-pattern \".pi/**\" --deny-warnings --no-error-on-unmatched-pattern",
    "markdownlint:fix": "node ./node_modules/markdownlint-cli/markdownlint.js \"**/*.md\" --ignore \"CHANGELOG.md\" --ignore \"node_modules/**\" --ignore \"dist/**\" --ignore \"external/**\" --ignore \"coverage/**\" --ignore \".pi/**\" --fix",
    "markdownlint:check": "node ./node_modules/markdownlint-cli/markdownlint.js \"**/*.md\" --ignore \"CHANGELOG.md\" --ignore \"node_modules/**\" --ignore \"dist/**\" --ignore \"external/**\" --ignore \"coverage/**\" --ignore \".pi/**\"",
    "test": "npm --silent run build && node --test test/*.test.ts",
    "typecheck": "npm --silent run build && node ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.test.json"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "markdownlint-cli": "0.48.0",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "packageManager": "npm@11.12.1"
}
